# Copy to .env and fill in.

# Hugging Face token with access to the gated VGGT / VGGT-Omega checkpoints.
# Request access on the model pages first, then create a token at
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Host port the web UI is served on.
WEB_PORT=8080

# Set to 0 to skip warming the default model at worker boot (faster startup,
# first inference pays the load cost instead).
WARM_DEFAULT_MODEL=1
